{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"sourceMap": true,
		"types": [
			"node",
			"vscode"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
