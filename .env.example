# This package requires no runtime environment variables for the CLI itself.
# Copy to `.env` only if you add private overrides locally (do not commit `.env`).

# Agent-test live dogfood (`bun run agent:test:live` / `agent:test:live:compare`).
# Export the key in your shell — the agent-test CLI does not auto-load `.env`.
# CURSOR_API_KEY=

# Optional model overrides for live agent / judge
# CURSOR_AGENT_MODEL=
# CURSOR_JUDGE_MODEL=

# Optional harness knobs — see @post-print/agent-test README
# AGENT_TEST_DEBUG=1
# AGENT_TEST_TIMEOUT_MS=600000
