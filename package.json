{
	"name": "@csark0812/skeleton",
	"version": "0.0.0",
	"description": "SSOT audit CLI for agent harness repos",
	"type": "module",
	"bin": {
		"skeleton": "./dist/cli.js"
	},
	"files": [
		"dist",
		"templates",
		"schemas"
	],
	"engines": {
		"node": ">=22"
	},
	"packageManager": "bun@1.2.21",
	"scripts": {
		"build": "bun build src/cli.ts --target=node --outfile=dist/cli.js",
		"test": "bun test",
		"test:audit": "bun test src/audit/__tests__",
		"prepack": "bun test && bun run build"
	},
	"dependencies": {
		"ajv": "^8.17.1",
		"github-slugger": "^2.0.0",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"tinyglobby": "^0.2.14",
		"unist-util-visit": "^5.0.0",
		"yaml": "^2.8.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.8",
		"@types/github-slugger": "^2.0.0",
		"typescript": "~5.8.3"
	}
}
